CONTEXT.md  68.0K
# Dev Team Configuration

version: "1.0"

# Database configuration for operational data (features, gate results, sessions, etc.)
# Defaults to SQLite at .devteam.db in the repo root.
# For shared/multi-user deployments, use PostgreSQL:
#   database:
#     driver: postgres
#     dsn: "host=localhost port=5432 user=devteam dbname=devteam sslmode=disable"
# Environment variables override this config:
#   DEVTEAM_DB_DRIVER=postgres
#   DEVTEAM_DB_DSN="host=localhost ..."
database:
  driver: sqlite3
  dsn: ""

pipeline:
  human_interaction_timeout_minutes: 30
  phases:
    - name: inception
      roles: [pm]
      gate: spec_approved
      artifacts: [spec.md, acceptance.md, repos.yaml]
      rules: rules/aidlc/core-workflow.md

    - name: planning
      roles: [architect]
      gate: plan_approved
      artifacts: [plan.md, research.md, data-model.md, contracts/, tasks.md]
      rules: rules/aidlc-rule-details/construction/

    - name: construction
      roles: [developer]
      gate: tasks_complete
      artifacts: [implementation across repos]
      rules: rules/aidlc-rule-details/construction/code-generation.md

    - name: review
      roles: [reviewer]
      gate: criteria_met
      artifacts: [review report]
      rules: rules/aidlc-rule-details/construction/functional-design.md

    - name: testing
      roles: [tester]
      gate: tests_pass
      artifacts: [test report]
      rules: rules/aidlc-rule-details/construction/build-and-test.md

# Repository Registry

# Maps feature specs to the implementation repos they touch.
# Each feature declares which repos are in scope.
# Implementation repos get a .devteam/ pointer back to the central spec.

repos:
  devteam:
    url: git@github.com:MichielDean/devteam.git
    description: Dev Team platform — orchestrator, roles, specs, and configuration
    primary: true

  cistern:
    url: git@github.com:MichielDean/cistern.git
    description: Agentic workflow orchestrator

  LLMem:
    url: git@github.com:MichielDean/LLMem.git
    description: Structured agent memory system

  lobsterdog:
    url: git@github.com:MichielDean/lobsterdog.git
    description: Agent harness — skills, identity, configuration

  ScaledTest:
    url: git@github.com:MichielDean/ScaledTest.git
    description: Test result management platform

  PortfolioWebsite:
    url: git@github.com:MichielDean/PortfolioWebsite.git
    description: Portfolio and resume website
