# Dev Team Configuration

version: "1.0"

# Database configuration for operational data (features, gate results, sessions, etc.)
# Defaults to SQLite at .devteam.db in the repo root.
# For shared/multi-user deployments, use PostgreSQL:
#   database:
#     driver: postgres
#     dsn: "host=localhost port=5432 user=devteam dbname=devteam sslmode=disable"
# Environment variables override this config:
#   DEVTEAM_DB_DRIVER=postgres
#   DEVTEAM_DB_DSN="host=localhost ..."
database:
  driver: sqlite3
  dsn: ""

pipeline:
  human_interaction_timeout_minutes: 30
  phases:
    - name: inception
      roles: [pm]
      gate: spec_approved
      artifacts: [spec.md, acceptance.md, repos.yaml]
      rules: rules/aidlc/core-workflow.md

    - name: planning
      roles: [architect]
      gate: plan_approved
      artifacts: [plan.md, research.md, data-model.md, contracts/, tasks.md]
      rules: rules/aidlc-rule-details/construction/

    - name: construction
      roles: [developer]
      gate: tasks_complete
      artifacts: [implementation across repos]
      rules: rules/aidlc-rule-details/construction/code-generation.md

    - name: review
      roles: [reviewer]
      gate: criteria_met
      artifacts: [review report]
      rules: rules/aidlc-rule-details/construction/functional-design.md

    - name: testing
      roles: [tester]
      gate: tests_pass
      artifacts: [test report]
      rules: rules/aidlc-rule-details/construction/build-and-test.md

    - name: delivery
      roles: [ops]
      gate: docs_match_spec
      artifacts: [docs, release]
      rules: rules/aidlc-rule-details/operations/operations.md

roles:
  pm:
    name: Product Manager
    description: Owns the what and why. Explores, clarifies, refines ideas into specs. Decomposes external roadmaps into feature specs.
