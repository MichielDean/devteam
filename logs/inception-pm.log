		{"CT_CATARACTA_NAME", req.Role},
		{"GIT_EDITOR", "true"},
		{"GIT_SEQUENCE_EDITOR", "true"},
		{"OPENCODE_SERVER_USERNAME", ""},
		{"OPENCODE_SERVER_PASSWORD", ""},
		{"OPENCODE_PID", ""},
		{"OPENCODE", ""},
	}
	for _, e := range envPairs {
		args = append(args, "-e", e.k+"="+e.v)
	}
