type Server struct {
	httpServer    *http.Server
	pipeline      *pipeline.Pipeline
	specProvider  *spec.SpecProvider
	db            *db.DB
	activeProcess sync.Map
	sseClients    sync.Map
	sseBuffers    sync.Map // featureID -> []*SSEMessage (recent events for late joiners)
