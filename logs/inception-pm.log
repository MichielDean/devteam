cmd/devteam/main.go           # CLI entrypoint
internal/
‚îú‚îÄ‚îÄ config/                    # YAML config loading
‚îú‚îÄ‚îÄ feature/                   # Feature state machine, types, gates
‚îú‚îÄ‚îÄ init/                       # Project initialization scaffolding
