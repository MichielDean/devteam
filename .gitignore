# Dev Team .gitignore

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/dist/

# Test binary
*.test

# Output of go coverage
*.out

# Go workspace file
go.work

# Dependency directories
/vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Spec Kit working files
.specify/memory/working/

# Build output
/devteam

# Playwright MCP logs
.playwright-mcp/

# Runtime data — all state lives in the database, never on disk
.devteam.db
.devteam.db-shm
.devteam.db-wal
specs/
logs/

# Chat RAG index — derived artifact (rebuilt by `devteam rag build`), not committed
.devteam/